@page "/"
@inject ILogger<UrlDTO> Logger
@using System.Text.Json
@using System.Text.Json.Serialization

@inject IHttpClientFactory ClientFactory

<PageTitle>Encurtador URL</PageTitle>

<div class="container">
    <div class="row">
        <div class="col align-middle">
            <h1>Encurtador de URL</h1>
        </div>
        <div class="col d-flex align-items-center">
            <p>Sobre</p>
        </div>
    </div>
    <div>
        <h1>Hello, world!</h1>
        <EditForm Model="Model" OnSubmit="Submit">
            <InputText @bind-Value="Model.Url" class="form-control" />
            <button type="submit" class="btn btn-primary mt-2">Encurtar URL</button>
        </EditForm>

        @if (resultado != null)
        {
            <p>Resposta da API: @resultado</p>
        }
    </div>
</div>

@code{
    private UrlDTO Model { get; set; } = new();
    private string? resultado;

    private async Task Submit()
    {
        Logger.LogInformation("Enviando URL: {url}", Model.Url);
        await ExecutarChamadaApi();
    }

    private async Task ExecutarChamadaApi()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            
            // Usando a forma mais moderna e segura que já cuida do JSON e Headers
            var response = await client.PostAsJsonAsync("http://localhost:5090/api/encurtador", Model);

            if (response.IsSuccessStatusCode)
            {
                resultado = await response.Content.ReadAsStringAsync();
                Logger.LogInformation("Sucesso!");
            }
            else
            {
                resultado = $"Erro: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            resultado = $"Erro de conexão: {ex.Message}";
            Logger.LogError(ex, "Falha ao conectar na API");
        }
    }

    public class UrlDTO
    {
        public string Url { get; set; } = string.Empty;
    }
}
